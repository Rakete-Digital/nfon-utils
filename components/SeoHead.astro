---
import { SEO, type TwitterCardType } from "astro-seo";

export interface Alternate {
  href: string;
  hreflang: string;
}

export interface Props {
  isBlog?: boolean;

  story?: any;
  canonical?: { href?: string; hreflang?: string };
  alternates?: Alternate[];

  title?: string;
  titleDefault?: string;
  description?: string;
  keywords?: string;
  author?: string;
  url?: string;
  noindex?: boolean;

  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;

  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  twitterCard?: TwitterCardType;

  robots?: string;
  charset?: string;
  refresh?: string;
  viewport?: string;
  contentType?: string;

  icons?: { rel: string; href: string }[];
  sitemap?: string;
}

const {
  isBlog = false,

  story,
  canonical,
  alternates,

  title,
  titleDefault = "",
  description,
  keywords,
  author,
  url,
  noindex,

  ogTitle,
  ogDescription,
  ogImage,

  twitterTitle,
  twitterDescription,
  twitterImage,
  twitterCard,

  robots,
  charset,
  refresh,
  viewport,
  contentType,

  icons,
  sitemap,
} = Astro.props;

const c = story?.content || {};
const ai = c.ai_seo || {};

// first non-empty value wins
const pick = (...values: (string | undefined)[]) =>
  values.find((v) => v && v.trim() !== "");

// SEO config
const seo = {
  title: pick(ai.title, c.og_title, c.title, c.Title, story?.name, title),
  description: pick(ai.description, c.description, description),
  keywords: pick(ai.keywords, c.keywords, keywords),
  noindex: noindex ?? c.noindex ?? false,
  author: pick(ai.author, c.author, author),
  url: pick(ai["og:url"], canonical?.href, url),

  ogTitle: pick(c.og_title, ai["og:title"], ai.title, c.title, c.Title, story?.name, ogTitle),
  ogDescription: pick(c.og_description, ai["og:description"], c.description, ogDescription),
  ogImage: pick(c.og_image?.filename, ai["og:image"], ogImage),

  twitterTitle: pick(ai["twitter:title"], ai.title, c.og_title, c.title, c.Title, story?.name, twitterTitle),
  twitterDescription: pick(ai["twitter:description"], c.description, twitterDescription),
  twitterImage: pick(ai["twitter:image"], c.og_image?.filename, twitterImage),
  twitterCard: pick(ai["twitter:card"], twitterCard, "summary_large_image") as TwitterCardType,

  robots: pick(ai["advanced:robots"], robots),
  charset: pick(ai["advanced:charset"], charset, "utf-8"),
  refresh: pick(ai["advanced:refresh"], refresh),
  viewport: pick(ai["advanced:viewport"], viewport, "width=device-width, initial-scale=1"),
  canonical: pick(ai["advanced:canonical"], canonical?.href),
  contentType: pick(ai["advanced:content-type"], contentType, "text/html; charset=utf-8"),
};

// meta tags
const meta: Partial<import("astro-seo").Meta>[] = [];
if (seo.keywords) meta.push({ name: "keywords", content: seo.keywords });
if (seo.robots) meta.push({ name: "robots", content: seo.robots });
if (seo.contentType) meta.push({ httpEquiv: "Content-Type", content: seo.contentType });
if (seo.refresh) meta.push({ httpEquiv: "refresh", content: seo.refresh });
if (seo.viewport) meta.push({ name: "viewport", content: seo.viewport });

// link tags
const link: { rel: string; href: string; hreflang?: string }[] = [];

if (icons) {
  link.push(...icons);
} else {
  link.push(
    { rel: "icon", href: "/assets/favicon.png" },
    { rel: "apple-touch-icon", href: "/assets/logo-nfon.svg" },
    { rel: "msapplication-TileImage", href: "/assets/logo-nfon.svg" }
  );
}

if (sitemap) link.push({ rel: "sitemap", href: sitemap });

// alternates
if (alternates?.length) {
  alternates.forEach((alt) =>
    link.push({ rel: "alternate", href: alt.href, hreflang: alt.hreflang })
  );
}

// canonical
if (seo.canonical) {
  link.push({ rel: "canonical", href: seo.canonical });
}

// final page title
const pageTitle = seo.title || (isBlog ? "NFON Blog" : titleDefault);
---

<SEO
  titleDefault={titleDefault}
  title={pageTitle}
  description={seo.description}
  charset={seo.charset}
  openGraph={{
    basic: {
      title: seo.ogTitle || "",
      type: "website",
      image: seo.ogImage || "",
      url: seo.url || "",
    },
    image: {
      alt: seo.ogTitle || pageTitle,
      height: 1920,
      width: 2400,
      url: seo.ogImage,
    },
    article: {
      authors: seo.author ? [seo.author] : [],
    },
  }}
  twitter={{
    card: seo.twitterCard,
    title: seo.twitterTitle,
    description: seo.twitterDescription,
    image: seo.twitterImage,
  }}
  extend={{
    link,
    meta,
  }}
/>