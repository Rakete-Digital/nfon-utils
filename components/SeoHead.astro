---
import { SEO, type TwitterCardType } from "astro-seo";

export interface Alternate {
  href: string;
  hreflang: string;
}

export interface Props {
  isBlog?: boolean;
  
  story?: any;
  canonical?: { href?: string; hreflang?: string };
  alternates?: Alternate[];

  // Optional overrides
  title?: string;
  titleDefault?: string;
  description?: string;
  keywords?: string;
  author?: string;
  url?: string;
  noindex?: boolean;

  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;

  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  twitterCard?: TwitterCardType;

  robots?: string;
  charset?: string;
  refresh?: string;
  viewport?: string;
  contentType?: string;

  icons?: { rel: string; href: string }[];
  sitemap?: string;
}

const {
  isBlog = false,

  story,
  canonical,
  alternates,

  title,
  titleDefault = "NFON",
  description,
  keywords,
  author,
  url,
  noindex,

  ogTitle,
  ogDescription,
  ogImage,

  twitterTitle,
  twitterDescription,
  twitterImage,
  twitterCard,

  robots,
  charset,
  refresh,
  viewport,
  contentType,

  icons,
  sitemap,
} = Astro.props;

// Storyblok fallbacks
const c = story?.content || {};
const ai = c.seo_plugin || {};

const pick = (...values: (string | undefined)[]) =>
  values.find((v) => v && v.trim() !== "");

const seo = {
  title: pick(c.title || c.Title, ai.title, story?.name, title),

  description: pick(c.description, ai.description, description),
  keywords: pick(c.keywords, ai.keywords, keywords),
  noindex: noindex ?? c.noindex ?? false,
  author: pick(c.author, ai.author, author),
  url: pick(canonical?.href, ai["og:url"], url),

  ogTitle: pick(c.title || c.Title, c.og_title, ai["og:title"], story?.name, ogTitle),
  ogDescription: pick(c.description, c.og_description, ai["og:description"], ogDescription),
  ogImage: pick(c.og_image?.filename, ai["og:image"], ogImage),

  twitterTitle: pick(c.title || c.Title, ai["twitter:title"], story?.name, twitterTitle),
  twitterDescription: pick(c.description, ai["twitter:description"], twitterDescription),
  twitterImage: pick(c.og_image?.filename, ai["twitter:image"], twitterImage),
  twitterCard: twitterCard ?? (ai["twitter:card"] as TwitterCardType) ?? "summary_large_image",

  robots: pick(ai["advanced:robots"], robots),
  charset: pick(ai["advanced:charset"], charset, "utf-8"),
  refresh: pick(ai["advanced:refresh"], refresh),
  viewport: pick(ai["advanced:viewport"], viewport, "width=device-width, initial-scale=1"),
  canonical: pick(canonical?.href, ai["advanced:canonical"]),
  contentType: pick(ai["advanced:content-type"], contentType, "text/html; charset=utf-8"),
};

// Meta array
const meta: Partial<import("astro-seo").Meta>[] = [];
if (seo.keywords) meta.push({ name: "keywords", content: seo.keywords });
if (seo.robots) meta.push({ name: "robots", content: seo.robots });
if (seo.contentType) meta.push({ httpEquiv: "Content-Type", content: seo.contentType });
if (seo.refresh) meta.push({ httpEquiv: "refresh", content: seo.refresh });
if (seo.viewport) meta.push({ name: "viewport", content: seo.viewport });

// Link array
const link: { rel: string; href: string; hreflang?: string }[] = [];
if (icons) link.push(...icons);
else {
  link.push(
    { rel: "icon", href: "/assets/favicon.png" },
    { rel: "apple-touch-icon", href: "/assets/logo-nfon.svg" },
    { rel: "msapplication-TileImage", href: "/assets/logo-nfon.svg" }
  );
}
if (sitemap) link.push({ rel: "sitemap", href: sitemap });

// Alternates
if (alternates && alternates.length > 0) {
  alternates.forEach((alt) => link.push({ rel: "alternate", href: alt.href, hreflang: alt.hreflang }));
}

// Canonical
if (seo.canonical) link.push({ rel: "canonical", href: seo.canonical });

const pageTitle = isBlog ? `NFON Blog | ${seo.title}` : seo.title || titleDefault; 
---

<SEO
  titleDefault={titleDefault}
  title={pageTitle}
  description={seo.description}
  charset={seo.charset}
  openGraph={{
    basic: {
      title: seo.ogTitle || "",
      type: "website",
      image: seo.ogImage || "",
      url: seo.url || "",
    },
    image: {
      alt: seo.ogTitle || pageTitle,
      height: 1920,
      width: 2400,
      url: seo.ogImage,
    },
    article: {
      authors: seo.author ? [seo.author] : [],
    },
  }}
  twitter={{
    card: seo.twitterCard,
    title: seo.twitterTitle,
    description: seo.twitterDescription,
    image: seo.twitterImage,
  }}
  extend={{
    link,
    meta,
  }}
/>
